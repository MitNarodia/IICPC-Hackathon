{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "id": 1,
      "title": "Ingest rate (events/s by type)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (rate(track3_ingest_events_total[1m]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Dead-letter rate (events/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops", "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(track3_ingest_deadletter_total[1m]))", "legendFormat": "dead-letter" }
      ]
    },
    {
      "id": 3,
      "title": "Ingest throughput (bytes/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "Bps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(track3_ingest_bytes_total[1m]))", "legendFormat": "bytes/s" }
      ]
    },
    {
      "id": 4,
      "title": "Service liveness (up)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ], "unit": "short" }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "up{job=\"track3-services\"}", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 5,
      "title": "Goroutines per service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 0 }, "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "go_goroutines{job=\"track3-services\"}", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 6,
      "title": "Resident memory per service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "process_resident_memory_bytes{job=\"track3-services\"}", "legendFormat": "{{instance}}" }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
