# Track 3 backend configuration (12-factor). Copy to .env and adjust as needed.
# These defaults match docker-compose; for local `go run` point them at exposed
# host ports instead (e.g. localhost:9092 / localhost:5432 / localhost:6379).

# --- Identity ---------------------------------------------------------------
# Set automatically per binary; override only for custom logging identity.
# SERVICE_NAME=ingestion-service

# --- Event bus (Redpanda / Kafka API) --------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_TLS=false

# --- Durable analytics store (PostgreSQL + TimescaleDB) --------------------
# Leave empty to disable persistence (pipeline still runs; no history/charts).
POSTGRES_DSN=postgres://track3:track3@localhost:5432/track3?sslmode=disable

# --- Hot leaderboard state (Redis) -----------------------------------------
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Network listeners ------------------------------------------------------
# HTTP_ADDR is used by ingestion-service and leaderboard-service.
HTTP_ADDR=:8080
METRICS_ADDR=:9100

# --- Windowing & flush cadence ---------------------------------------------
WINDOW_SIZE=5s
SLIDE_INTERVAL=1s
ROLLING_RETENTION=60s
FLUSH_INTERVAL=1s

# --- Scoring weights (must reflect relative priorities; need not sum to 1) --
WEIGHT_LATENCY=0.35
WEIGHT_THROUGHPUT=0.30
WEIGHT_CORRECTNESS=0.25
WEIGHT_STABILITY=0.10

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=info
