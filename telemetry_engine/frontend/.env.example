# Frontend build/runtime config. Copy to .env.local for overrides.
#
# Base URL for the leaderboard REST API. Leave empty to use same-origin (the
# Vite dev proxy or the nginx reverse proxy in production both serve /v1 there).
VITE_API_BASE=
# Base URL for the WebSocket. Empty => derive from window.location.
VITE_WS_BASE=
# Dev-only: where `vite dev` proxies /v1 to.
VITE_PROXY_TARGET=http://localhost:8080
