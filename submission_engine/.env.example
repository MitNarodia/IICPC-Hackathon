# Track 1 — Local Development Environment
# Copy to .env and modify as needed (docker-compose.yml uses these as defaults)

DATABASE_URL=postgres://track1:track1@localhost:5432/track1?sslmode=disable
KAFKA_BROKERS=localhost:9092
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=raw-uploads
S3_BUCKET_BUILD_LOGS=build-logs
S3_FORCE_PATH_STYLE=true
S3_REGION=us-east-1
